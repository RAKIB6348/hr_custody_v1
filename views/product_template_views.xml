<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="product_template_form_view_inherit_custody_brand" model="ir.ui.view">
        <field name="name">product.template.form.inherit.custody.brand</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='group_standard_price']/field[@name='categ_id']" position="after">
                <field name="brand_id" options="{'no_open': True}"/>
                <field name="model_name"/>
                <field name="specification"/>
            </xpath>
        </field>
    </record>
</odoo>
