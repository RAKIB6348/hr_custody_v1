<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_hr_custody" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.hr.custody</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="stock.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@name='operations_setting_container']" position="inside">
                <setting id="custody_stock_locations_setting"
                         string="Custody Transfer Locations"
                         help="Locations used when assets are delivered to an employee.">
                    <div class="content-group">
                        <label string="Company Stock Location" for="custody_stock_source_location_id"/>
                        <field name="custody_stock_source_location_id"
                               options="{'no_open': True, 'no_create': True}"
                               domain="[('usage','=','internal'), '|', ('company_id', '=', False), ('company_id', 'child_of', [company_id])]"
                               class="oe_inline"/>
                        <div class="text-muted mt4">
                            Internal location that acts as the source (e.g. WH/Stock).
                        </div>
                    </div>
                </setting>
            </xpath>
        </field>
    </record>
</odoo>
